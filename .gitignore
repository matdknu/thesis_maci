# macOS / RStudio cruft
.DS_Store
.RData
.RDataTmp
.Rhistory
.Rproj.user/

# Python caches
__pycache__/
*.pyc

# Logs
*.log

# Datos brutos y procesados (no versionar)
data/raw/
data/processed/
data/**/*.csv
data/**/*.parquet
data/**/*.rds
data/**/*.xlsx
data/**/*.numbers

# Mantener figuras de outputs en el repo
!outputs_ml/*.png
!outputs_ml/*.csv

# Copia editorial unificada para la tesis (QMD/HTML/PDF)
!documents/tesis_book/fig_thesis/*.png
!documents/tesis_book/fig_thesis/*.csv

# Presentación Reveal (`presentation.qmd`, HTML, imágenes): se mantiene íntegra en el repositorio —
# no usar aquí patrones que excluyan `documents/presentacion_proyecto/`.

# Backups y artefactos temporales
backups/
scripts/analisis/__pycache__/
scripts/analisis/*.pyc

# Borradores de revisión y PDF locales sueltos (no libro publicado desde Quarto en docs/)
revision/
/Rplots.pdf

# Entornos virtuales locales
.venv/
venv/

# Materiales bibliográficos didácticos grandes (opcional fuera del control de versiones)
bibliografia/Speech and Language Processing/

# Claves/API (lista no exhaustiva; ver también scripts/... incluidos locales)
**/claves_Api

# Cachés de Quarto/knitr (no afectan al PDF final)
documents/tesis_book/_freeze/
documents/tesis_book/.quarto/
.Rproj.user
.Rhistory
.RData
.Ruserdata
