  author = {Kingzette, Jon and Druckman, James N and Klar, Samara and Krupnikov, Yanna and Levendusky, Matthew and Ryan, John Barry},
  year = 2021,
  month = oct,
  journal = {Public Opinion Quarterly},
  volume = {85},
