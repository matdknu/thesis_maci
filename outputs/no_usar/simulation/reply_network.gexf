        <attvalues>
          <attvalue for="0" value="OP_mod" />
          <attvalue for="1" value="neutral" />
          <attvalue for="2" value="0" />
          <attvalue for="3" value="¿Qué opinan de que la candidata comunista ahora se declare socialdemócrata? ¿Giro real o puro cálculo?" />
        </attvalues>
      </node>
      <node id="c01" label="c01">
        <attvalues>
          <attvalue for="0" value="RadRight_Rafa" />
          <attvalue for="1" value="radical_right" />
          <attvalue for="2" value="70" />
          <attvalue for="3" value="Aunque los comunistas chilenos siempre han apoyado su democracia, se declaran marxistas revolucionarios&quot;.. Lo que es contradictorio.&quot;" />
        </attvalues>
      </node>
      <node id="c02" label="c02">
